{
  "version": 2,
  "rewrites": [
    {
      "source": "/detalle/:categoria/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|WhatsApp|Twitterbot|LinkedInBot).*"
        }
      ],
      "destination": "/api/og-spider?id=:id"
    }
  ]
}