  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:alfonso-ugarte-ullulluco": "node dist/alfonso-ugarte-ullulluco/server/server.mjs",
    "deploy": "ng build --configuration production --base-href \"https://JORDYROJAS93.github.io/portal-ullulluco/\" && npx ngh --dir dist/alfonso-ugarte-ullulluco/browser"
